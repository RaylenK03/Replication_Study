# Part 3: Getis-Ord Gi Hotspot Analysis - Seattle, WA Metro Area

seattle_cbsa <- core_based_statistical_areas(cb = TRUE, year = 2020) %>%
  filter(str_detect(NAME, "Seattle-Tacoma-Bellevue")) %>%
  st_transform(2285)   # Washington North (feet)

# Download Washington tracts with ACS median household income
stb_tracts <- get_acs(
  geography = "tract",
  variables = "B19013_001",
  state = "WA",
  year = 2020,
  geometry = TRUE
) %>%
  st_transform(2285) %>%
  st_filter(seattle_cbsa, .predicate = st_within) %>%
  drop_na(estimate)

neighbors <- poly2nb(stb_tracts, queen = TRUE)

weights <- nb2listw(neighbors, style = "W", zero.policy = TRUE)

# Compute Getis-Ord Gi
localg_weights <- nb2listw(include.self(neighbors), zero.policy = TRUE)
stb_tracts$localG <- as.numeric(localG(stb_tracts$estimate, localg_weights))

# Classify hotspots
stb_tracts <- stb_tracts %>%
  mutate(hotspot = case_when(
    localG >= 2.56 ~ "High cluster",
    localG <= -2.56 ~ "Low cluster",
    TRUE ~ "Not significant"
  ))

# Map hotspots
ggplot(stb_tracts) +
  geom_sf(aes(fill = hotspot), color = "grey85", linewidth = 0.1) +
  scale_fill_manual(values = c(
    "High cluster" = "darkgreen",
    "Low cluster" = "goldenrod",
    "Not significant" = "grey90"
  )) +
  theme_void() +
  labs(
    title = "Getis-Ord Gi* Hotspot Analysis of Median Household Income",
    subtitle = "Seattle–Tacoma–Bellevue Metropolitan Area",
    fill = "Cluster Type",
    caption = "ACS 2016–2020 5-year estimates"
  )


